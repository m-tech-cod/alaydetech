---
// src/components/organisms/Footer.astro
const currentYear = new Date().getFullYear();
---

<footer class="bg-[#0F172A] text-white/80 border-t border-white/5">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid md:grid-cols-3 gap-8">
      
      <!-- Colonne 1 : Marque -->
      <div>
        <a href="/" class="flex items-center gap-3 mb-4 group">
          <img 
            src="/images/logo.webp" 
            alt="Alayde Tech" 
            class="h-10 w-auto object-contain rounded-xl transition-transform duration-300 group-hover:scale-105"
          />
        </a>
        <p class="text-sm text-white/60 max-w-xs">
          Alayde Tech, un code utile ici, et au-delà 💻🌎🌿
        </p>
        <!-- RCCM/IFU directement sous le slogan -->
        <div class="mt-4 text-xs text-white/30 space-y-1">
          <p>RCCM : RB/PNO/26 A 126770</p>
          <p>IFU : 0202238028015</p>
        </div>
      </div>

      <!-- Colonne 2 : Liens rapides -->
      <div>
        <h4 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Liens rapides</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/services" class="text-white/60 hover:text-white transition-colors duration-200">Services</a></li>
          <li><a href="/projects" class="text-white/60 hover:text-white transition-colors duration-200">Réalisations</a></li>
          <li><a href="/about" class="text-white/60 hover:text-white transition-colors duration-200">À propos</a></li>
          <li><a href="/contact" class="text-white/60 hover:text-white transition-colors duration-200">Contact</a></li>
          <li><a href="/blog" class="text-white/60 hover:text-white transition-colors duration-200">Blog</a></li>
        </ul>
      </div>

      <!-- Colonne 3 : Contact & Réseaux -->
      <div>
        <h4 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Restons connectés</h4>
        <p class="text-sm text-white/40 mb-4">
          <a href="mailto:malomonaraffath@gmail.com" class="hover:text-white transition-colors duration-200">
            malomonaraffath@gmail.com
          </a>
        </p>
        <div class="flex gap-3">
          <a
            href="https://www.facebook.com/share/1H5BPk3gRm/?mibextid=wwXIfr"
            target="_blank"
            rel="noopener noreferrer"
            class="w-10 h-10 bg-white/10 rounded-full flex items-center justify-center hover:bg-[#1877F2] transition-colors duration-300 hover:scale-110"
            aria-label="Facebook"
          >
            <i class="fab fa-facebook-f text-sm"></i>
          </a>
          <a
            href="https://www.linkedin.com/company/alayde-tech"
            target="_blank"
            rel="noopener noreferrer"
            class="w-10 h-10 bg-white/10 rounded-full flex items-center justify-center hover:bg-[#0A66C2] transition-colors duration-300 hover:scale-110"
            aria-label="LinkedIn"
          >
            <i class="fab fa-linkedin-in text-sm"></i>
          </a>
          <a
            href="https://github.com/m-tech-cod"
            target="_blank"
            rel="noopener noreferrer"
            class="w-10 h-10 bg-white/10 rounded-full flex items-center justify-center hover:bg-[#181717] transition-colors duration-300 hover:scale-110"
            aria-label="GitHub"
          >
            <i class="fab fa-github text-sm"></i>
          </a>
          <a
            href="https://wa.me/22996427604"
            target="_blank"
            rel="noopener noreferrer"
            class="w-10 h-10 bg-white/10 rounded-full flex items-center justify-center hover:bg-[#25D366] transition-colors duration-300 hover:scale-110"
            aria-label="WhatsApp"
          >
            <i class="fab fa-whatsapp text-sm"></i>
          </a>
        </div>
      </div>
    </div>

    <!-- Liens légaux en bas -->
    <div class="border-t border-white/5 mt-10 pt-6 flex flex-wrap items-center justify-between gap-4 text-xs text-white/40">
      <div class="flex flex-wrap gap-4">
        <a href="/legal" class="hover:text-white transition-colors duration-200">Mentions légales</a>
        <span class="text-white/20">|</span>
        <a href="/privacy" class="hover:text-white transition-colors duration-200">Politique de confidentialité</a>
      </div>
      <span>&copy; {currentYear} Alayde Tech. Tous droits réservés.</span>
    </div>
  </div>
</footer>