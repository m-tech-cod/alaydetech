---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Contact" description="Contactez Alayde Tech pour vos projets web, SaaS ou solutions numériques.">
  <section class="py-20 px-4">
    <div class="max-w-5xl mx-auto">
      <!-- En-tête -->
      <div class="text-center mb-12">
        <h1 class="text-3xl md:text-5xl font-bold text-[#1E3A8A]">
          Prenons <span class="text-[#F59E0B]">contact</span>
        </h1>
        <p class="text-gray-600 mt-4 max-w-2xl mx-auto">
          Vous avez un projet en tête ? Discutons-en ensemble.
        </p>
        <div class="w-20 h-1 bg-[#F59E0B] mx-auto mt-4 rounded"></div>
      </div>

      <div class="grid md:grid-cols-2 gap-12">
        <!-- Formulaire -->
        <div class="bg-white rounded-xl shadow-md p-6 md:p-8">
          <h2 class="text-xl font-semibold text-[#1E3A8A] mb-6">Envoyez-nous un message</h2>

          <form
            id="contact-form"
            action="https://formspree.io/f/meenwbvo"
            method="POST"
            class="space-y-5"
          >
            <div>
              <label for="name" class="block text-sm font-medium text-gray-700 mb-1">
                Nom complet
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-[#1E3A8A] focus:border-transparent transition"
                placeholder="Alain Dupuis"
              />
            </div>

            <div>
              <label for="email" class="block text-sm font-medium text-gray-700 mb-1">
                Email
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-[#1E3A8A] focus:border-transparent transition"
                placeholder="vous@exemple.com"
              />
            </div>

            <div>
              <label for="subject" class="block text-sm font-medium text-gray-700 mb-1">
                Sujet
              </label>
              <input
                type="text"
                id="subject"
                name="subject"
                class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-[#1E3A8A] focus:border-transparent transition"
                placeholder="Demande de devis"
              />
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-gray-700 mb-1">
                Message
              </label>
              <textarea
                id="message"
                name="message"
                rows="5"
                required
                class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-[#1E3A8A] focus:border-transparent transition resize-none"
                placeholder="Décrivez votre projet..."
              ></textarea>
            </div>

            <button
              id="submit-btn"
              type="submit"
              class="w-full bg-[#1E3A8A] text-white font-semibold py-3 px-6 rounded-lg hover:bg-[#1E3A8A]/90 transition shadow-md hover:shadow-lg"
            >
              Envoyer le message
            </button>

            <p
              id="form-message"
              class="hidden rounded-lg p-4 text-sm font-medium"
            ></p>
          </form>
        </div>

        <!-- Infos de contact -->
        <div class="space-y-8">
          <div>
            <h2 class="text-xl font-semibold text-[#1E3A8A] mb-4">Autres moyens</h2>
            <p class="text-gray-600 mb-6">
              Vous pouvez aussi nous contacter directement via :
            </p>

            <div class="space-y-4">
              <!-- WhatsApp -->
              <a
                href="https://wa.me/22996427604"
                target="_blank"
                rel="noopener noreferrer"
                class="w-14 h-14 bg-[#25D366] text-white rounded-full flex items-center justify-center text-2xl hover:scale-110 transition"
                aria-label="WhatsApp"
              >
                <i class="fab fa-whatsapp"></i>
              </a>
            </div>
          </div>

          <!-- Réseaux sociaux -->
          <div>
            <h3 class="text-lg font-semibold text-[#1E3A8A] mb-4">Suivez-nous</h3>
            <div class="flex flex-wrap gap-4">
              <a
                href="https://www.facebook.com/share/18DPKwjdcL/?mibextid=wwXIfr"
                target="_blank"
                rel="noopener noreferrer"
                class="w-14 h-14 bg-[#1877F2] text-white rounded-full flex items-center justify-center text-2xl hover:scale-110 transition"
                aria-label="Facebook"
              >
                <i class="fab fa-facebook-f"></i>
              </a>
              <a
                href="https://www.linkedin.com/company/alayde-tech"
                target="_blank"
                rel="noopener noreferrer"
                class="w-14 h-14 bg-[#0A66C2] text-white rounded-full flex items-center justify-center text-2xl hover:scale-110 transition"
                aria-label="LinkedIn"
              >
                <i class="fab fa-linkedin-in"></i>
              </a>
              <a
                href="https://github.com/m-tech-cod"
                target="_blank"
                rel="noopener noreferrer"
                class="w-14 h-14 bg-[#181717] text-white rounded-full flex items-center justify-center text-2xl hover:scale-110 transition"
                aria-label="GitHub"
              >
                <i class="fab fa-github"></i>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<!-- Font Awesome pour les icônes sociales -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const form = document.getElementById("contact-form");
    const message = document.getElementById("form-message");
    const button = document.getElementById("submit-btn");
    const originalText = button.innerHTML;

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      message.classList.add("hidden");

      button.disabled = true;
      button.innerHTML = `
        <svg class="animate-spin h-5 w-5 inline-block mr-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
        </svg>
        Envoi en cours...
      `;
      button.classList.add("opacity-70", "cursor-not-allowed");

      const data = new FormData(form);

      try {
        const response = await fetch(form.action, {
          method: "POST",
          body: data,
          headers: {
            Accept: "application/json"
          }
        });

        if (response.ok) {
          message.className = "mt-4 rounded-lg bg-green-100 text-green-800 p-4 text-sm font-medium";
          message.textContent = "🎉 Merci ! Votre message a bien été envoyé. Nous vous répondrons dans les plus brefs délais.";
          message.classList.remove("hidden");
          form.reset();

          setTimeout(() => {
            message.classList.add("hidden");
          }, 6000);

          button.classList.remove("opacity-70", "cursor-not-allowed");
          button.innerHTML = "✅ Message envoyé";
          button.classList.remove("bg-[#1E3A8A]");
          button.classList.add("bg-green-600");

          setTimeout(() => {
            button.disabled = false;
            button.innerHTML = originalText;
            button.classList.remove("bg-green-600");
            button.classList.add("bg-[#1E3A8A]");
          }, 1000);
        } else {
          button.disabled = false;
          button.innerHTML = originalText;
          button.classList.remove("opacity-70", "cursor-not-allowed");

          message.className = "mt-4 rounded-lg bg-red-100 text-red-800 p-4 text-sm font-medium";
          message.textContent = "❌ Une erreur est survenue. Veuillez réessayer.";
          message.classList.remove("hidden");

          setTimeout(() => {
            message.classList.add("hidden");
          }, 6000);
        }
      } catch (error) {
        button.disabled = false;
        button.innerHTML = originalText;
        button.classList.remove("opacity-70", "cursor-not-allowed");

        message.className = "mt-4 rounded-lg bg-red-100 text-red-800 p-4 text-sm font-medium";
        message.textContent = "❌ Impossible d'envoyer le message. Vérifiez votre connexion.";
        message.classList.remove("hidden");
      }
    });
  });
</script>