---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Services" description="Découvrez nos services : développement web, SaaS, solutions métier, ONG et maintenance.">
  <section class="py-20 px-4 max-w-6xl mx-auto">
    <div class="text-center mb-16 animate-fade-in-up">
      <span class="text-sm font-semibold text-[#F59E0B] uppercase tracking-wider">Nos services</span>
      <h1 class="text-4xl md:text-5xl font-bold text-[#1E3A8A] mt-2">
        Ce que nous <span class="text-[#F59E0B]">faisons</span>
      </h1>
      <p class="text-lg text-[#64748B] mt-4 max-w-2xl mx-auto">
        Des solutions digitales sur mesure pour répondre à vos besoins.
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      <div class="bg-white rounded-2xl shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-1 p-6 animate-fade-in-up animate-delay-1">
        <div class="w-14 h-14 bg-[#1E3A8A]/10 rounded-xl flex items-center justify-center text-3xl mb-4">🌐</div>
        <h3 class="text-xl font-semibold text-[#1E3A8A]">Développement Web</h3>
        <p class="text-[#64748B] text-sm mt-2 leading-relaxed">Sites vitrines, applications web complexes et plateformes sur mesure avec les technologies modernes.</p>
        <ul class="mt-4 space-y-2 text-sm text-[#64748B]">
          <li class="flex items-center gap-2">✓ React, Next.js, Astro</li>
          <li class="flex items-center gap-2">✓ TypeScript, Tailwind CSS</li>
          <li class="flex items-center gap-2">✓ Performance et SEO optimisés</li>
        </ul>
      </div>

      <div class="bg-white rounded-2xl shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-1 p-6 animate-fade-in-up animate-delay-2">
        <div class="w-14 h-14 bg-[#10B981]/10 rounded-xl flex items-center justify-center text-3xl mb-4">☁️</div>
        <h3 class="text-xl font-semibold text-[#1E3A8A]">SaaS & Plateformes</h3>
        <p class="text-[#64748B] text-sm mt-2 leading-relaxed">Solutions logicielles en tant que service, évolutives, sécurisées et adaptées à votre activité.</p>
        <ul class="mt-4 space-y-2 text-sm text-[#64748B]">
          <li class="flex items-center gap-2">✓ Architecture modulaire et scalable</li>
          <li class="flex items-center gap-2">✓ Authentification et paiements intégrés</li>
          <li class="flex items-center gap-2">✓ Tableaux de bord analytics</li>
        </ul>
      </div>

      <div class="bg-white rounded-2xl shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-1 p-6 animate-fade-in-up animate-delay-3">
        <div class="w-14 h-14 bg-[#F59E0B]/10 rounded-xl flex items-center justify-center text-3xl mb-4">🏢</div>
        <h3 class="text-xl font-semibold text-[#1E3A8A]">Solutions Métier</h3>
        <p class="text-[#64748B] text-sm mt-2 leading-relaxed">Outils internes, ERP, CRM et applications métier personnalisées pour optimiser vos processus.</p>
        <ul class="mt-4 space-y-2 text-sm text-[#64748B]">
          <li class="flex items-center gap-2">✓ Gestion des utilisateurs et rôles</li>
          <li class="flex items-center gap-2">✓ Rapports et visualisations</li>
          <li class="flex items-center gap-2">✓ Intégration avec vos outils existants</li>
        </ul>
      </div>

      <div class="bg-white rounded-2xl shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-1 p-6 animate-fade-in-up animate-delay-2">
        <div class="w-14 h-14 bg-[#1E3A8A]/10 rounded-xl flex items-center justify-center text-3xl mb-4">🤝</div>
        <h3 class="text-xl font-semibold text-[#1E3A8A]">Solutions ONG</h3>
        <p class="text-[#64748B] text-sm mt-2 leading-relaxed">Plateformes de gestion, collecte de fonds et suivi de projets humanitaires.</p>
        <ul class="mt-4 space-y-2 text-sm text-[#64748B]">
          <li class="flex items-center gap-2">✓ Gestion des bénéficiaires et projets</li>
          <li class="flex items-center gap-2">✓ Collecte de dons sécurisée</li>
          <li class="flex items-center gap-2">✓ Rapports d'impact automatisés</li>
        </ul>
      </div>

      <div class="bg-white rounded-2xl shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-1 p-6 animate-fade-in-up animate-delay-3">
        <div class="w-14 h-14 bg-[#10B981]/10 rounded-xl flex items-center justify-center text-3xl mb-4">🛠️</div>
        <h3 class="text-xl font-semibold text-[#1E3A8A]">Maintenance & Support</h3>
        <p class="text-[#64748B] text-sm mt-2 leading-relaxed">Support technique, maintenance évolutive et optimisation continue de vos plateformes.</p>
        <ul class="mt-4 space-y-2 text-sm text-[#64748B]">
          <li class="flex items-center gap-2">✓ Surveillance 24/7</li>
          <li class="flex items-center gap-2">✓ Mises à jour de sécurité</li>
          <li class="flex items-center gap-2">✓ Support prioritaire</li>
        </ul>
      </div>

      <div class="bg-white rounded-2xl shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-1 p-6 animate-fade-in-up animate-delay-4">
        <div class="w-14 h-14 bg-[#F59E0B]/10 rounded-xl flex items-center justify-center text-3xl mb-4">🎯</div>
        <h3 class="text-xl font-semibold text-[#1E3A8A]">Sites Vitrines</h3>
        <p class="text-[#64748B] text-sm mt-2 leading-relaxed">Sites institutionnels, landing pages et vitrines digitales modernes pour votre marque.</p>
        <ul class="mt-4 space-y-2 text-sm text-[#64748B]">
          <li class="flex items-center gap-2">✓ Design premium et personnalisé</li>
          <li class="flex items-center gap-2">✓ Optimisé pour la conversion</li>
          <li class="flex items-center gap-2">✓ Intégration CMS facile</li>
        </ul>
      </div>
    </div>

    <div class="text-center mt-12 animate-fade-in-up">
      <a href="/contact" class="inline-block bg-[#1E3A8A] text-white font-semibold px-8 py-3 rounded-xl hover:bg-[#1E3A8A]/90 transition-all hover:shadow-lg hover:-translate-y-0.5">
        Discuter de votre projet
      </a>
    </div>
  </section>
</BaseLayout>